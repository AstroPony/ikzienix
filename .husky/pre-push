#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

echo "Running tests and build before pushing..."

# Run tests
npm run test || {
    echo "❌ Tests failed. Please fix the tests before pushing."
    exit 1
}

# Run build
npm run build || {
    echo "❌ Build failed. Please fix the build errors before pushing."
    exit 1
}

echo "✅ All checks passed! Proceeding with push..." 